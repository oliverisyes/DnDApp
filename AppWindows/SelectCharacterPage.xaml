<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DnDApp.AppWindows.SelectCharacterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:DnDApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid>
		<Grid>
			<TextBlock x:Name="DnDApp"/>
		</Grid>

		<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
			<Grid Width="500" Margin="0 0 0 10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="200"/>
					<ColumnDefinition Width="auto"/>
					<ColumnDefinition Width="auto"/>
					<ColumnDefinition Width="auto"/>
				</Grid.ColumnDefinitions>

				<AutoSuggestBox PlaceholderText="Enter character name" QueryIcon="Find" Grid.Column="0"/>
				<Button Content="New Character" Click="NewCharButton_Click" Style="{ThemeResource AccentButtonStyle}" Grid.Column="1" Margin="10 0 10 0"/>
				<Button Content="Open Character" Style="{ThemeResource AccentButtonStyle}" Grid.Column="2"/>
				<Button Click="SettingsButton_Click" Background="Transparent" BorderBrush="Transparent" Width="35" Height="35" Grid.Column="3" Padding="0" Margin="7 0 0 0" CornerRadius="100">
					<SymbolIcon Symbol="Setting"/>
				</Button>
			</Grid>

			<!--<Line Stroke="DimGray" X1="0" Y1="0" X2="200" Y2="0" StrokeThickness="1" Margin="10"/>-->

			<ItemsStackPanel>
				
			</ItemsStackPanel>
			
			<ScrollView Height="300">
				<StackPanel x:Name="charPanel" Spacing="5">
					<controls:CharacterSelectButton/>
					<controls:CharacterSelectButton/>
					<controls:CharacterSelectButton/>
					<controls:CharacterSelectButton/>
				</StackPanel>
			</ScrollView>
		</StackPanel>

		<controls:AppSettingsPopup x:Name="Popup"/>
	</Grid>
</Page>